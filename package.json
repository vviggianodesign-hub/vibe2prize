{
  "name": "vibe2prize",
  "version": "1.0.0",
  "description": "This repository hosts the **Enhanced Vibe-to-Enterprise Framework** deck as a fully themeable [Reveal.js](https://revealjs.com/) presentation. The content lives in `vibe2prize.md`, and `index.html` renders it with custom EPAM styling plus a light/dark toggle.",
  "type": "module",
  "main": "index.js",
  "directories": {
    "example": "example"
  },
  "scripts": {
    "build:slides": "node builder/build-slides.js",
    "dev": "node builder/build-slides.js --watch",
    "dev:static": "node scripts/dev-static.js",
    "studio": "node scripts/template-studio.js",
    "build:studio": "node scripts/build-template-studio.js",
    "lint:slides": "node builder/lint-slides.js",
    "analyze:content": "node builder/content-analyzer.js",
    "build": "npm run build:slides",
    "test": "node --test --import ./template-studio/test/test-setup.js ./template-studio/test/*.test.js",
    "test:mdx": "node --test template-studio/test/importer.test.js template-studio/test/exporter.test.js template-studio/test/schema-validation.test.js",
    "test:regression": "node --test template-studio/test/regression.test.js template-studio/test/integration.test.js template-studio/test/visual-regression.test.js",
    "test:watch": "node --test --watch template-studio/test/*.test.js"
  },
  "keywords": [],
  "author": "FLOCC",
  "license": "MIT",
  "dependencies": {
    "@mdx-js/esbuild": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "ajv": "^8.13.0",
    "esbuild": "^0.27.3",
    "fs-extra": "^11.3.3",
    "gray-matter": "^4.0.3",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "jsdom": "^25.0.1"
  }
}
